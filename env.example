# Copy to .env.local

# Replicate (image gen): https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Pinata (IPFS pinning): https://pinata.cloud
PINATA_JWT=

# Upstash Redis (tx dedup + gallery): https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# MegaETH contract
NEXT_PUBLIC_MEGACHAD_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BURN_AMOUNT=1000

# Dev wallet — receives 50% of every burn (set in contract constructor)
# Used by deploy script: DEV_WALLET=0xYourWalletAddress
DEV_WALLET=

# Chain: testnet=6342, mainnet=4326
# NEXT_PUBLIC_MEGAETH_CHAIN_ID=6342

# Meridian x402 payments: https://mrdn.finance
MERIDIAN_API_KEY=

# ERC-8004 Agent ID (from Identity Registry registration)
MEGACHAD_AGENT_ID=

# Gasless relayer contract (deployed via contracts/script/DeployRelayer.s.sol)
NEXT_PUBLIC_RELAYER_CONTRACT=

# Telegram Bot: https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=
